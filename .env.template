# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Optional: override the default model used for summaries and chat
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Optional: enable Logfire tracing if you want observability during the workshop
LOGFIRE_TOKEN=

# Optional: directories for persistent app data and MCP-created notes
APP_DATA_DIR=./data
APP_NOTES_DIR=./workshop_notes

# Logging Configuration
# Set log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG will show detailed information, INFO for general operations
LOG_LEVEL=DEBUG
